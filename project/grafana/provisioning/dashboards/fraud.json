{
  "title": "Fraud Detector",
  "uid": "fraud-detector",
  "schemaVersion": 38,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Requests per second",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "rate(fraud_requests_total[1m])",
        "legendFormat": "{{endpoint}} {{status}}"
      }]
    },
    {
      "id": 2,
      "title": "Request latency p95 (seconds)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "histogram_quantile(0.95, rate(fraud_request_duration_seconds_bucket[1m]))",
        "legendFormat": "p95 {{endpoint}}"
      }]
    },
    {
      "id": 3,
      "title": "Fraud detected (total)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "fraud_detected_total",
        "legendFormat": "Fraud"
      }]
    },
    {
      "id": 4,
      "title": "Cache hit ratio",
      "type": "stat",
      "gridPos": { "x": 6, "y": 8, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "fraud_cache_hits_total / (fraud_cache_hits_total + fraud_cache_misses_total)",
        "legendFormat": "Hit ratio"
      }]
    },
    {
      "id": 5,
      "title": "Backend memory (MB)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "process_resident_memory_bytes / 1024 / 1024",
        "legendFormat": "RSS MB"
      }]
    }
  ]
}
